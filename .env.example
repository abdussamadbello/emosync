# Async SQLAlchemy (FastAPI)
DATABASE_URL=postgresql+asyncpg://emosync:emosync@localhost:5432/emosync

# Sync URL for Alembic migrations (no +asyncpg)
DATABASE_URL_SYNC=postgresql://emosync:emosync@localhost:5432/emosync

# Comma-separated origins for CORS
CORS_ORIGINS=http://localhost:3000

# Optional. When set, chat routes require Authorization: Bearer <api_key> or X-API-Key.
# Leave unset for local dev; set in staging/prod (e.g. GitHub Environment secret).
# API_KEY=

# Gemini API key for the LangGraph agent pipeline (Historian/Specialist/Anchor).
# When unset, chat returns a deterministic stub response (safe for CI / local dev).
# Get your key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=
